# ============================================
# DASHUP SERVER - CONFIGURAÇÃO DE AMBIENTE
# ============================================
# Copie este arquivo para .env e configure as variáveis conforme necessário
# cp .env-example .env

# ============================================
# CONFIGURAÇÃO DO SERVIDOR
# ============================================
NODE_ENV=development
PORT=1818

# Origem permitida para CORS (frontend URL)
# Para desenvolvimento local, use: http://localhost:5173
# Para produção, use a URL do seu frontend
CORS_ORIGIN=http://localhost:5173

# ============================================
# CONFIGURAÇÃO DO BANCO DE DADOS (MongoDB)
# ============================================
# Formato da URL: mongodb://[usuário]:[senha]@[host]:[porta]/[database]?authSource=admin
# 
# Para desenvolvimento local (MongoDB local):
# DATABASE_URL=mongodb://localhost:27017/dashup
#
# Para Docker Compose:
DATABASE_URL=mongodb://admin:admin123@localhost:27017/dashup?authSource=admin
#
# Para MongoDB Atlas (cloud):
# DATABASE_URL=mongodb+srv://usuario:senha@cluster.mongodb.net/dashup?retryWrites=true&w=majority

# ============================================
# AUTENTICAÇÃO JWT
# ============================================
# Chave secreta para assinar e verificar tokens JWT
# IMPORTANTE: Use uma string longa e aleatória em produção
# Você pode gerar uma com: openssl rand -base64 32
AUTH_SECRET=your-super-secret-jwt-key-change-this-in-production-minimum-32-characters

# ============================================
# CONFIGURAÇÃO CLOUDINARY (Upload de Imagens/Vídeos)
# ============================================
# Obtenha essas credenciais em: https://cloudinary.com/console
# Cloudinary é usado para armazenar imagens de animes, personagens, etc.
CLOUD_NAME=your-cloudinary-cloud-name
CLOUD_API_KEY=your-cloudinary-api-key
CLOUD_API_SECRET=your-cloudinary-api-secret

# ============================================
# CONFIGURAÇÃO MONGODB (Para Docker Compose)
# ============================================
# Essas variáveis são usadas apenas quando rodando com docker-compose
# Elas configuram o usuário root do MongoDB
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=admin123

# ============================================
# NOTAS IMPORTANTES
# ============================================
# 1. NUNCA commite o arquivo .env no Git
# 2. Em produção, use variáveis de ambiente do seu provedor (Heroku, Vercel, etc.)
# 3. AUTH_SECRET deve ser uma string longa e aleatória (mínimo 32 caracteres)
# 4. Para desenvolvimento local sem Docker, você pode usar MongoDB local sem autenticação:
#    DATABASE_URL=mongodb://localhost:27017/dashup
# 5. CORS_ORIGIN deve corresponder à URL do seu frontend
